# Required Telegram bot token from BotFather
BOT_TOKEN=123456789:REPLACE_WITH_YOUR_BOTFATHER_TOKEN

# Main admin/owner Telegram chat IDs. Separate multiple admins with commas.
# Admin actions are done from the website, but these IDs are kept as owner records.
ADMIN_IDS=123456789,987654321

# Admin contact(s) shown to unregistered users when they send /start.
# Separate multiple usernames/IDs with commas. If empty, ADMIN_IDS will be shown instead.
BOT_ADMIN_CONTACTS=@youradmin,123456789

# Public support username/contact used by /support and the Support button.
# Use a Telegram username like @your_support for the direct chat button.
SUPPORT_USERNAME=@your_support

# Required fallback admin website login. The website uses these only until you save login credentials in Secret Settings.
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=change-this-password

# Optional stable cookie secret. Recommended on Railway so logins survive restarts.
ADMIN_SESSION_SECRET=change-this-long-random-secret

# Use true only when your admin panel is HTTPS. Railway is HTTPS, local Windows is HTTP.
ADMIN_COOKIE_SECURE=false

# Time/caption settings
BOT_TZ=Asia/Kolkata

# Storage
# Local testing can use SQLite. Live deployment should use MongoDB.
# Set MONGO_URI on Railway/Render/VPS and you do NOT need a persistent disk volume.
STORAGE_BACKEND=mongodb
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=upi_autopay_bot
MONGO_STATE_COLLECTION=bot_state
MONGO_SNAPSHOT_ID=upi_autopay_main
MONGO_SYNC_ON_COMMIT=true
# DB_PATH is only the temporary runtime cache when STORAGE_BACKEND=mongodb.
DB_PATH=/tmp/upi_autopay_bot.db

# Local testing: polling is simplest and the admin website still runs on PORT.
# Important: run only one instance at a time. Two polling instances will break updates.
MODE=polling

# Optional Railway webhook mode:
# MODE=webhook
# WEBHOOK_URL=https://your-service.up.railway.app
WEBHOOK_URL=
WEBHOOK_SECRET_TOKEN=
PORT=8080

# Privacy/safety
# true = receiver/sender can forward, save, and download the bot-generated clean QR.
# This does NOT forward the sender's original photo or reveal usernames.
ALLOW_FORWARD_DOWNLOAD=true
PROTECT_CONTENT=false
STORE_QR_DATA=false

# Delete originals after success/rejection.
DELETE_ORIGINAL_AFTER_SUCCESS=true
DELETE_ORIGINAL_AFTER_REJECTION=true
DELETE_STATUS_COMMAND_AFTER_USE=true

# QR validation mode. Default accepts only UPI AutoPay / mandate creation QR payloads.
QR_VALIDATION_MODE=upi_mandate
REJECT_UPI_ONETIME_MANDATES=true

# Optional generic QR safety options, used only when QR_VALIDATION_MODE=generic.
BLOCK_CONTACT_PATTERNS=true
STRICT_QR_REGEX=
ALLOWED_QR_PREFIXES=

# Performance
MAX_PROCESS_DIMENSION=1600
LOG_LEVEL=INFO


# Open marketplace
QR_EXPIRE_MINUTES=5
MARKETPLACE_WATCH_INTERVAL_SECONDS=10
PAYMENT_WATCH_INTERVAL_SECONDS=30
PAYMENT_WATCH_BATCH_SIZE=25
PAYMENT_WATCH_CONCURRENCY=5
PAYMENT_AUTO_VERIFY_TIMEOUT_SECONDS=15
PAYMENT_TIMEOUT_MINUTES=30
PAYMENT_REMINDER_MINUTES=20
MANUAL_VERIFICATION_DELAY_MINUTES=5
DEFAULT_SENDER_RATE_USDT=0
DEFAULT_RECEIVER_RATE_USDT=0
DEFAULT_MIN_PAYOUT_USDT=1
DEFAULT_MIN_WALLET_TOPUP_USDT=1
BEP20_MANUAL_TOLERANCE_USDT=0.01
POLYGON_MANUAL_TOLERANCE_USDT=0.07
BINANCE_MANUAL_TOLERANCE_USDT=0.00

# Payment details can be saved from the web admin Payments page.
BEP20_WALLET_ADDRESS=
POLYGON_WALLET_ADDRESS=
BINANCE_PAY_ID=
BINANCE_PAY_NAME=

# Crypto payment verification APIs can be saved from Secret Settings.
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=
# RPC fallback keeps auto/manual checks working when Scan APIs lag or rate-limit.
# Multiple URLs are tried newest-first and in block chunks, like the working payment project.
BEP20_RPC_URL=https://bsc-rpc.publicnode.com
POLYGON_RPC_URL=https://polygon-rpc.com
BEP20_RPC_URLS=https://bsc-rpc.publicnode.com,https://bsc.drpc.org,https://rpc.ankr.com/bsc,https://bsc-dataseed.binance.org
POLYGON_RPC_URLS=https://polygon-rpc.com,https://polygon-bor-rpc.publicnode.com,https://polygon.drpc.org,https://rpc.ankr.com/polygon
BEP20_RPC_BLOCK_CHUNK_SIZE=450
POLYGON_RPC_BLOCK_CHUNK_SIZE=500
ETHERSCAN_API_KEY=
EVM_LOG_LOOKBACK_BLOCKS=50000
BEP20_REQUIRED_CONFIRMATIONS=3
POLYGON_REQUIRED_CONFIRMATIONS=20
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_BASE_URL=https://api.binance.com
BINANCE_PAY_HISTORY_LOOKBACK_SECONDS=3600
BINANCE_RECV_WINDOW_MS=5000
# Max seconds a foreground payment check can run before asking for screenshot/admin review
PAYMENT_VERIFY_TASK_TIMEOUT_SECONDS=30
